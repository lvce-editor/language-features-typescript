{
  "id": "builtin.language-features-typescript",
  "name": "Language Features TypeScript",
  "description": "TypeScript Language Support",
  "browser": "dist/languageFeaturesTypeScriptMain.js",
  "isolated": true,
  "repository": "https://github.com/lvce-editor/language-features-typescript",
  "icon": "icon.png",
  "activation": [
    "onBraceCompletion:javascript",
    "onBraceCompletion:typescript",
    "onCompletion:typescript",
    "onCompletion:javascript",
    "onDefinition:javascript",
    "onDefinition:typescript",
    "onDiagnostic:javascript",
    "onDiagnostic:typescript",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact",
    "onRename:javascript",
    "onRename:typescript",
    "onReferences:javascript",
    "onReferences:typescript",
    "onImplementation:javascript",
    "onImplementation:typescript",
    "onClosingTag:javascript",
    "onClosingTag:typescript",
    "onTypeDefinition:typescript",
    "onHover:javascript",
    "onHover:typescript",
    "onTabCompletion:javascript",
    "onTabCompletion:typescript"
  ],
  "completionProviders": [
    { "id": "typescript.provideCompletions.javascript", "languageId": "javascript" },
    { "id": "typescript.provideCompletions.typescript", "languageId": "typescript" },
    { "id": "typescript.provideCompletions.typescriptreact", "languageId": "typescriptreact" }
  ],
  "diagnosticProviders": [
    { "id": "typescript.provideDiagnostics.javascript", "languageId": "javascript" },
    { "id": "typescript.provideDiagnostics.typescript", "languageId": "typescript" },
    { "id": "typescript.provideDiagnostics.typescriptreact", "languageId": "typescriptreact" }
  ],
  "hoverProviders": [
    { "id": "typescript.provideHover.javascript", "languageId": "javascript" },
    { "id": "typescript.provideHover.typescript", "languageId": "typescript" },
    { "id": "typescript.provideHover.typescriptreact", "languageId": "typescriptreact" }
  ],
  "languages": [
    {
      "id": "typescript",
      "extensions": [".ts"]
    },
    {
      "id": "typescriptreact",
      "extensions": [".tsx"]
    },
    {
      "id": "javascript",
      "extensions": [".js"]
    },
    {
      "id": "javascriptreact",
      "extensions": [".jsx"]
    }
  ],
  "codeActions": [
    {
      "kind": "source.organizeImports",
      "name": "Organize Imports",
      "command": "Editor.organizeImports",
      "languageId": "typescript"
    },
    {
      "kind": "source.sortImports",
      "name": "Sort Imports",
      "command": "Editor.sortImports",
      "languageId": "typescript"
    }
  ],
  "jsonValidation": [
    {
      "fileMatch": "tsconfig.json",
      "url": "./schemas/tsconfig.schema.json"
    },
    {
      "fileMatch": "tsconfig-*.json",
      "url": "./schemas/tsconfig.schema.json"
    },
    {
      "fileMatch": "tsconfig.*.json",
      "url": "./schemas/tsconfig.schema.json"
    },
    {
      "fileMatch": "jsconfig.json",
      "url": "./schemas/jsconfig.schema.json"
    },
    {
      "fileMatch": "jsconfig.*.json",
      "url": "./schemas/jsconfig.schema.json"
    }
  ]
}

{
  "name": "builtin.language-features-typescript-monorepo",
  "version": "0.0.0-dev",
  "description": "TypeScript language features monorepo for LVCE Editor",
  "license": "MIT",
  "author": "LVCE Editor",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "node packages/build/src/build.ts",
    "build:static": "node packages/build/src/build-static.ts",
    "build:watch": "node packages/build/src/build-watch.ts",
    "dev": "node packages/build/src/dev.ts",
    "e2e": "npm run e2e --workspace=packages/e2e",
    "e2e:headless": "npm run e2e:headless --workspace=packages/e2e",
    "format": "prettier --write .",
    "postinstall": "node packages/build/src/postinstall.ts",
    "lint": "eslint . && prettier --check .",
    "test": "npm test --workspaces --if-present",
    "type-check": "tsc -b"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 120
  },
  "dependencies": {
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@lvce-editor/api": "^8.53.1",
    "@lvce-editor/eslint-config": "^16.5.0",
    "eslint": "^10.7.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.5",
    "ts-jest": "^29.4.11"
  }
}
